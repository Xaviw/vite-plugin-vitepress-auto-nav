{
  "name": "vite-plugin-vitepress-auto-nav",
  "type": "module",
  "version": "4.0.0",
  "packageManager": "pnpm@10.11.0",
  "description": "自动生成vitepress的nav与sidebar",
  "author": "xavi",
  "license": "MIT",
  "homepage": "https://xaviw.github.io/XaviDocs/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xaviw/vite-plugin-vitepress-auto-nav.git"
  },
  "bugs": "https://github.com/Xaviw/vite-plugin-vitepress-auto-nav/issues",
  "keywords": [
    "vitepress",
    "vite-plugin",
    "vitepress-plugin",
    "vitepress-auto",
    "vitepress-gitbook",
    "vitepress-summary",
    "auto-nav",
    "auto-sidebar",
    "auto-menu"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "types"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "eslint . --fix",
    "clean": "npx -y rimraf node_modules dist",
    "taze": "npx -y taze -I",
    "postinstall": "npx -y simple-git-hooks",
    "inspect:lint": "npx -y @eslint/config-inspector",
    "inspect:dep": "npx -y node_modules_inspector"
  },
  "peerDependencies": {
    "vite": "*",
    "vitepress": "*"
  },
  "dependencies": {
    "front-matter": "^4.0.2",
    "minimatch": "^10.0.1",
    "tinyglobby": "^0.2.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.13.0",
    "@types/node": "^22.15.18",
    "eslint": "^9.26.0",
    "lint-staged": "^16.0.0",
    "rollup": "^4.40.2",
    "rollup-plugin-typescript2": "^0.36.0",
    "simple-git-hooks": "^2.13.0",
    "typescript": "^5.8.3",
    "vite": "*",
    "vitepress": "*"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
