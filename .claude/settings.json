{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "allowedMcpServers": [
    { "serverName": "context7" },
    { "serverName": "github-grep" },
    { "serverName": "sequential-thinking" },
    { "serverName": "serena" },
    { "serverName": "zai-search" },
    { "serverName": "zai-reader" }
  ],
  "permissions": {
    "allow": [
      "mcp__context7",
      "mcp__github-grep",
      "mcp__sequential-thinking",
      "mcp__serena",
      "mcp__zai-search",
      "mcp__zai-reader",
      "Bash"
    ],
    "deny": ["Read(*.local)", "Bash(rm:*)"]
  }
}
